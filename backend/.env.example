# =============================================================================
# OmniForm analyzer configuration
# Copy this file to `.env` and fill in your values.
# =============================================================================

# --- Option A: Gemini Developer API (simplest for the hackathon) -------------
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# --- Option B: Vertex AI on Google Cloud ------------------------------------
# Uses Application Default Credentials (run `gcloud auth application-default login`).
# Leave GEMINI_API_KEY blank and set these instead:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Google Cloud Text-to-Speech (the agent's voice) -------------------------
# Reuses GEMINI_API_KEY by default. For Cloud TTS the key must have the
# "Cloud Text-to-Speech API" enabled (console.cloud.google.com). If unset or
# unauthorized, the client falls back to the browser's built-in speech.
# GOOGLE_TTS_API_KEY=your_cloud_tts_key
# GOOGLE_TTS_VOICE=en-US-Chirp3-HD-Charon   # newest Chirp 3 HD voice (default)

# --- Optional overrides ------------------------------------------------------
# GEMINI_MODEL=gemini-3.5-flash     # default; use gemini-3.5-pro for max reasoning
# PORT=8080

# --- Security guardrails (see SECURITY.md) -----------------------------------
# Comma-separated origin allowlist for CORS. Defaults to localhost dev URLs;
# set this to your deployed frontend URL in prod.
# ALLOWED_ORIGIN=https://omniform-frontend-xxxx.run.app

# Optional shared token. When set, the backend requires X-Demo-Token to match
# on every /api/analyze call. Frontend reads from NEXT_PUBLIC_DEMO_TOKEN.
# Leave blank for local dev to keep the no-auth happy path working.
# DEMO_TOKEN=
