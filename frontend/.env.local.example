# Override the analyzer endpoint if the backend runs somewhere other than localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080/api/analyze

# Shared demo token. Backend requires X-Demo-Token to match its DEMO_TOKEN env
# var. Leave blank for local dev; set both sides to the same value in deploys.
# Note: NEXT_PUBLIC_* is shipped in the client bundle — this is a friction
# bump, not real auth. Combine with the backend rate limit.
# NEXT_PUBLIC_DEMO_TOKEN=
